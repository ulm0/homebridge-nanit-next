{
  "name": "homebridge-nanit-next",
  "displayName": "Nanit for Homebridge",
  "type": "module",
  "version": "1.0.6",
  "description": "Homebridge plugin for Nanit baby cameras with native HomeKit integration: live streaming (local/cloud/auto), two-way audio (not supported yet, only listening is available at the moment), night light, sound machine, and sensors.",
  "author": "ulm0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ulm0/homebridge-nanit-next.git"
  },
  "bugs": {
    "url": "https://github.com/ulm0/homebridge-nanit-next/issues"
  },
  "homepage": "https://github.com/ulm0/homebridge-nanit-next#readme",
  "keywords": [
    "homebridge-plugin",
    "nanit",
    "baby-monitor",
    "homekit",
    "camera"
  ],
  "main": "dist/index.js",
  "engines": {
    "node": "^20.18.0 || ^22.10.0 || ^24.0.0",
    "homebridge": "^1.11.0 || ^2.0.0-beta.0"
  },
  "files": [
    "dist",
    "src/nanit/protobuf/nanit.proto",
    "config.schema.json",
    "homebridge-ui"
  ],
  "scripts": {
    "build": "rimraf ./dist && tsc",
    "watch": "npm run build && npm link && nodemon",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^2.2.1",
    "node-media-server": "^4.2.4",
    "pick-port": "^2.2.0",
    "protobufjs": "^8.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@types/ws": "^8.18.1",
    "homebridge": "^1.11.2",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3"
  }
}
